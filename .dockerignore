# Keep the build context (and image) lean — only pyproject/README/LICENSE/src
# are needed to install the package.
.git
.github
.venv
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/
htmlcov/
.coverage

# Not needed at runtime (the API serves JSON/NDJSON; static pages are hosted
# separately via GitHub Pages / htmlpreview).
tests/
samples/
docs/
out/
atlas-drafts/
.claude/
